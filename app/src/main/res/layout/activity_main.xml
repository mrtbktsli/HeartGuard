<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="❤️ HeartGuard"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#D32F2F"
            android:gravity="center"
            android:paddingBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kalp Ritmi İzleme"
            android:textSize="14sp"
            android:textColor="#757575"
            android:gravity="center"
            android:paddingBottom="20dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:background="#FFEBEE"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/tvHeartRate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nabız: -- bpm"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#C62828"/>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bekleniyor..."
                android:textSize="13sp"
                android:textColor="#757575"/>
        </LinearLayout>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Çocuğun Adı" android:textStyle="bold" android:textColor="#424242" android:paddingBottom="4dp"/>
        <EditText android:id="@+id/etChildName" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="Örn: Zeynep"
            android:background="#FFFFFF" android:padding="12dp" android:layout_marginBottom="12dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Ebeveyn Telefon" android:textStyle="bold" android:textColor="#424242" android:paddingBottom="4dp"/>
        <EditText android:id="@+id/etParentPhone" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="Örn: 05551234567"
            android:inputType="phone" android:background="#FFFFFF" android:padding="12dp" android:layout_marginBottom="12dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Üst Limit (bpm)" android:textStyle="bold" android:textColor="#424242" android:paddingBottom="4dp"/>
        <EditText android:id="@+id/etUpperLimit" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="Örn: 160"
            android:inputType="number" android:background="#FFFFFF" android:padding="12dp" android:layout_marginBottom="12dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Alt Limit (bpm)" android:textStyle="bold" android:textColor="#424242" android:paddingBottom="4dp"/>
        <EditText android:id="@+id/etLowerLimit" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="Örn: 40"
            android:inputType="number" android:background="#FFFFFF" android:padding="12dp" android:layout_marginBottom="20dp"/>

        <Button android:id="@+id/btnSave" android:layout_width="match_parent"
            android:layout_height="50dp" android:text="💾 Kaydet"
            android:backgroundTint="#1976D2" android:textColor="#FFFFFF" android:layout_marginBottom="10dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="60dp"
            android:background="#E8F5E9" android:orientation="horizontal"
            android:gravity="center_vertical" android:padding="12dp" android:layout_marginBottom="10dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="🟢 İzlemeyi Başlat"
                android:textSize="15sp" android:textStyle="bold" android:textColor="#2E7D32"/>
            <Switch android:id="@+id/swService" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <Button android:id="@+id/btnTestSms" android:layout_width="match_parent"
            android:layout_height="50dp" android:text="📱 Test SMS Gönder"
            android:backgroundTint="#FF6F00" android:textColor="#FFFFFF"/>

    </LinearLayout>
</ScrollView>
